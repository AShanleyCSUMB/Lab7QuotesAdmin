<%- include('partials/header') %>

<h1>Quotes</h1>

<p>Update or delete saved quotes.</p>
<p><a href="/quotes/new">Add Quote</a></p>

<% if (successMessage) { %>
  <p><%= successMessage %></p>
<% } %>

<% if (errorMessage) { %>
  <p><%= errorMessage %></p>
<% } %>

<% if (!quotes || quotes.length === 0) { %>
  <p>No quotes found.</p>
<% } else { %>
  <table border="1" cellpadding="6">
    <thead>
      <tr>
        <th>Quote</th>
        <th>Author</th>
        <th>Category</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% quotes.forEach(item => { %>
        <tr>
          <td>“<%= item.quote %>”</td>
          <td><%= item.firstName || 'Unknown' %> <%= item.lastName || '' %></td>
          <td><%= item.categoryName || 'Uncategorized' %></td>
          <td>
            <a href="/quotes/update/<%= item.quoteId %>" class="btn btn-warning btn-sm">Update</a>

            <form action="/quotes/delete/<%= item.quoteId %>" method="POST" style="display:inline;">
              <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this quote?');">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('partials/footer') %>