<%- include('partials/header') %>

<h1>Quote Finder Admin Panel</h1>

<p>Add authors, manage quotes, and browse saved content.</p>

<% if (isLoggedIn) { %>
  <p>
    <a href="/authors/new">Add Author</a>
    <a href="/quotes/new">Add Quote</a>
  </p>
<% } else { %>
  <p>
    <a href="/login">Login</a> to manage authors and quotes.
  </p>
<% } %>

<h2>Recent Quotes</h2>

<% if (!quotes || quotes.length === 0) { %>
  <p>No quotes found yet.</p>
<% } else { %>
  <% quotes.forEach(q => { %>
    <div>
      <blockquote>“<%= q.quote %>”</blockquote>
      <p>
        <strong><%= q.firstName || 'Unknown' %> <%= q.lastName || 'Author' %></strong>
        - <%= q.categoryName || 'Uncategorized' %>
      </p>
    </div>
  <% }) %>
<% } %>

<%- include('partials/footer') %>