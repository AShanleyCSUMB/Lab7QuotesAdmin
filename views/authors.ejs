<%- include('partials/header') %>

<h1>Authors</h1>

<p><a href="/authors/new">Add Author</a></p>

<% if (!authors || authors.length === 0) { %>
  <p>No authors found.</p>
<% } else { %>
  <table border="1" cellpadding="6">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Profession</th>
        <th>Country</th>
        <th>Sex</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% authors.forEach(author => { %>
        <tr>
          <td><%= author.authorId %></td>
          <td><%= author.firstName %> <%= author.lastName %></td>
          <td><%= author.profession || '' %></td>
          <td><%= author.country || '' %></td>
          <td><%= author.sex || '' %></td>
          <td>
            <a href="/authors/update/<%= author.authorId %>">Update</a>

            <form method="POST" action="/authors/delete/<%= author.authorId %>" style="display:inline;">
              <button type="submit" onclick="return confirm('Delete this author?');">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('partials/footer') %>